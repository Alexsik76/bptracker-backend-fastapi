# Copy to .env and fill in. Do NOT commit .env to git (only this example).
# These three are read by both docker compose and the application.
POSTGRES_USER=bp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bp_tracker

# Database connection URL for the application.
# The driver prefix (+asyncpg / +psycopg) is deliberately omitted here -
# it will be added once the database access layer strategy is finalized (see README -> "Open Decision").
DATABASE_URL=postgresql://bp:change-me@localhost:5432/bp_tracker
